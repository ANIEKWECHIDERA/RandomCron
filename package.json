{
  "name": "random-cron-worker",
  "version": "1.0.0",
  "description": "A production-ready randomized cron-style HTTP worker with Resend alerts.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pm2:start": "pm2 start ecosystem.config.cjs"
  },
  "keywords": [
    "cron",
    "worker",
    "resend",
    "fetch"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "resend": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
