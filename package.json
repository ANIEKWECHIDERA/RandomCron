{
  "name": "random-cron-worker",
  "version": "1.0.0",
  "description": "A production-ready randomized cron-style HTTP worker with Resend alerts.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "npm run build:server && npm run build:web",
    "build:server": "prisma generate && tsc -p tsconfig.json",
    "build:web": "vite build",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:web": "tsc -p frontend/tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "test:phase1": "tsx src/tests/phase1-persistence.ts",
    "test:phase2": "tsx src/tests/phase2-scheduler.ts",
    "test:phase3": "tsx src/tests/phase3-api.ts",
    "pm2:start": "pm2 start ecosystem.config.cjs"
  },
  "keywords": [
    "cron",
    "worker",
    "resend",
    "fetch"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.2",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "pino": "^9.6.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "resend": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prisma": "^6.19.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
